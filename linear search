#include <stdio.h>
int main() {
    int arr[100], n, i, choice, pos, value;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);
    do {
        printf("\n1.Insert\n2.Delete\n3.Update\n4.Display\n5.Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        switch(choice) {
        case 1:
            printf("Enter Position: ");
            scanf("%d", &pos);
            printf("Enter Value: ");
            scanf("%d", &value);
            for(i = n; i >= pos; i--)
                arr[i] = arr[i-1];
            arr[pos-1] = value;
            n++;
            break;
        case 2:
            printf("Enter Position: ");
            scanf("%d", &pos);
            for(i = pos-1; i < n-1; i++)
                arr[i] = arr[i+1];
            n--;
            break;
        case 3:
            printf("Enter Position: ");
            scanf("%d", &pos);
            printf("Enter New Value: ");
            scanf("%d", &value);
            arr[pos-1] = value;
            break;
        case 4:
            printf("Array Elements: ");
            for(i = 0; i < n; i++)
                printf("%d ", arr[i]);
            printf("\n");
            break;
        }
    } while(choice != 5);
   return 0;
}
